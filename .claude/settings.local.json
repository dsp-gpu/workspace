{
  "permissions": {
    "allow": [
      "Bash(cmake --build*)",
      "Bash(cmake --preset*)",
      "Bash(cmake -B*)",
      "Bash(python3*)",
      "Bash(make*)",
      "Bash(ninja*)",
      "Bash(bash .claude/hooks/*)",
      "mcp__sequential-thinking__*",
      "mcp__context7__*",
      "mcp__filesystem__*",
      "mcp__memory__*",
      "mcp__sqlite__*",
      "mcp__git__*",
      "mcp__fetch__*",
      "mcp__dap-debug__get-call-stack",
      "mcp__dap-debug__evaluate-expression",
      "mcp__dap-debug__step-over",
      "mcp__dap-debug__step-into",
      "mcp__dap-debug__step-out",
      "mcp__dap-debug__continue",
      "mcp__dap-debug__get-debug-state",
      "mcp__dap-debug__get-variables-scope",
      "mcp__dap-debug__get-debug-console",
      "Bash(python -c \"import json,sys; data=json.load\\(sys.stdin\\); print\\(data[0][''text'']\\)\")",
      "Bash(echo \"EXIT: $?\")",
      "Bash(cp ./DSP/Doc/Modules/signal_generators/*.md ./signal_generators/Doc/)",
      "Bash(cp -r ./DSP/Doc/Modules/signal_generators/images/. ./signal_generators/Doc/images/)",
      "Bash(cp ./DSP/Doc/Modules/heterodyne/*.md ./heterodyne/Doc/)",
      "Bash(cp ./DSP/Doc/Modules/heterodyne/Алгоритм*.md ./heterodyne/Doc/)",
      "Bash(cp ./DSP/Doc/Modules/heterodyne/images/*.png ./heterodyne/Doc/images/)",
      "Bash(cp ./DSP/Doc/Modules/strategies/*.md ./strategies/Doc/)",
      "Bash(cp -r ./DSP/Doc/Modules/strategies/images/. ./strategies/Doc/images/)",
      "Bash(cp ./DSP/Doc/DrvGPU/*.md ./core/Doc/)",
      "Bash(cp ./DSP/Doc/DrvGPU/Services/*.md ./core/Doc/Services/)",
      "Bash(grep -iE \"rocm\\\\.cpp$|regularizer\")",
      "mcp__supermemory__memory",
      "mcp__supermemory__recall",
      "Read(//e/DSP-GPU/~!Doc/CMake-GIT/**)",
      "Read(//e/DSP-GPU/~!Doc/CMake/**)",
      "Read(//e/DSP-GPU/~!Doc/CMake/Version/**)",
      "mcp__claude_ai_Context7__resolve-library-id",
      "WebSearch",
      "Bash(./tests/test_linalg_main)",
      "Bash(tee /tmp/linalg_task1_binary.log)",
      "Bash(size build/libDspCore.a)",
      "Bash(ctest -R test_core_main --output-on-failure --timeout 60)",
      "Bash(./test_core_main --baseline)",
      "Bash(./build/tests/test_core_main)",
      "Bash(ctest --test-dir build --output-on-failure)",
      "Bash(echo \"EXIT=$?\")",
      "Bash(./tests/test_core_main)",
      "Bash(ctest --output-on-failure)",
      "Bash(ctest --preset local-dev)",
      "Bash(ctest --help)",
      "Bash(timeout 60 ./build/tests/test_spectrum_main)",
      "Bash(timeout 60 /home/alex/DSP-GPU/core/build/tests/test_core_main)",
      "Bash(/home/alex/DSP-GPU/core/build/tests/test_core_main)",
      "Bash(awk '{for\\(i=1;i<=NF;i++\\) if\\($i~/[0-9]+\\\\/[0-9]+/\\) print $i}')",
      "Bash(./build/tests/test_linalg_main)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on_stop.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre_bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_write.sh"
          }
        ]
      }
    ]
  }
}
