# ============================================================================
#  rag-pao — env config example
# ============================================================================

# --- LLM backends ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000

QWEN_FILLER_MODEL=qwen2.5-coder:14b-q4_K_M
QWEN_JUDGE_MODEL=qwen3.6:35b-q4_K_M

# --- BGE-M3 embed server -----------------------------------------------------
BGE_M3_URL=http://localhost:8765
BGE_M3_DIM=1024

# --- BGE reranker server -----------------------------------------------------
BGE_RERANKER_URL=http://localhost:8766

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag_pao
POSTGRES_PASSWORD=<set-locally>
POSTGRES_DB_PREFIX=rag_pao_                # schemas: rag_pao_pao_contrib, rag_pao_pao_xxxx_acme, ...

# --- Qdrant ------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Run-time (D24 + D25) ----------------------------------------------------
RAG_PAO_MODE=debug                         # debug | production
PAO_DROPS_DIR=/srv                         # root for pao_<name>/ drops
RAGCTL_STAGE=prod_ubuntu                   # dev_debian | prod_ubuntu
RAGCTL_TARGET=pao_contrib

# --- FastAPI server ----------------------------------------------------------
RAG_PAO_API_HOST=0.0.0.0
RAG_PAO_API_PORT=8080

# --- Sync (D29) --------------------------------------------------------------
RAG_PAO_BARE_REMOTE=/srv/git-remotes/rag-pao.git
