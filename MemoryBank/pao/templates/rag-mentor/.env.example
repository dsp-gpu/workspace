# ============================================================================
#  rag-mentor — env config example
#  Copy to .env or config/secrets.env (НЕ коммитить с реальными значениями!)
# ============================================================================

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...            # или работаем через Claude Code без ключа
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6

# --- mentor_db (PG schema rag_mentor) ----------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB_MENTOR=rag_mentor
POSTGRES_USER=rag_mentor
POSTGRES_PASSWORD=<set-locally>

# --- mentor_v1 (Qdrant collection) -------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_MENTOR_COLLECTION=mentor_v1

# --- Run-time (D24 + D25) ----------------------------------------------------
RAG_PAO_MODE=debug                       # debug | production (D25)
PAO_DROPS_DIR=/srv                       # root for pao_<name>/ drops
RAGCTL_STAGE=dev_debian                  # dev_debian | prod_ubuntu
RAGCTL_TARGET=pao_contrib

# --- rag-pao endpoint (REST API) ---------------------------------------------
RAG_PAO_URL=http://localhost:8080        # local (через SSH tunnel -L 8080:8080)
RAG_PAO_TIMEOUT_SEC=30

# --- Sync (D29) --------------------------------------------------------------
RAG_PAO_BARE_REMOTE=ssh://alex@10.10.4.105:/srv/git-remotes/rag-pao.git
