  #   source: "/srv/pao_xxxx_acme"
  #   nda_level: customer-A
  #   indexable: true
  #   primary_modules: [module_X, module_Y]
  #   layout:
  #     modules_dir: "modules"            # может быть другая раскладка
  #     cmake_infra_dir: "cmake"
  #     our_overlays:
  #       docs: "Doc"
  #       examples: "Example"
  #       native_tests: "Test"
  #       gtest: "GTest"
