{
  "_comment": "Dev stack — laptop Debian + local rag-pao через SSH tunnel",

  "anthropic": {
    "model_oracle":     "claude-opus-4-7",
    "model_reviewer":   "claude-sonnet-4-6",
    "model_critic":     "claude-opus-4-7"
  },

  "rag_pao": {
    "url":            "http://localhost:8080",
    "transport":      "rest",
    "timeout_sec":    30,
    "max_retries":    3
  },

  "mentor_db": {
    "postgres":  { "host": "localhost", "port": 5432, "database": "rag_mentor", "schema": "rag_mentor" },
    "qdrant":    { "url": "http://localhost:6333", "collection": "mentor_v1" }
  },

  "qwen_models": {
    "filler": { "name": "qwen2.5-coder:14b-q4_K_M", "backend": "ollama" },
    "judge":  { "name": "qwen3.6:35b-q4_K_M",       "backend": "ollama", "queue_swap": true }
  },

  "embedder": {
    "name":     "BAAI/bge-m3",
    "endpoint": "http://localhost:8765",
    "dim":      1024
  },

  "reranker": {
    "name":     "BAAI/bge-reranker-v2-m3",
    "endpoint": "http://localhost:8766"
  },

  "policy": {
    "max_retries":          3,
    "judge_threshold":      80,
    "reviewer_threshold":   80,
    "comparator_threshold": 80,
    "temperature_filler":   0.3,
    "temperature_judge":    0.0,
    "temperature_oracle":   0.2,
    "reviewer_sample_pct":  100
  }
}
